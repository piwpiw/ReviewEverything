{
    "name": "web",
    "version": "0.1.0",
    "private": true,
    "prisma": {
        "seed": "tsx ./prisma/seed.ts"
    },
    "scripts": {
        "postinstall": "prisma generate",
        "dev": "next dev",
        "check": "node scripts/guard.js",
        "build": "npm run check && next build",
        "start": "next start",
        "lint": "eslint",
        "lint:ci": "eslint . --format json --output-file reports/eslint.json",
        "typecheck": "tsc --noEmit",
        "release": "node scripts/release.js --auto-commit",
        "verify:local": "npm run deploy:target-check && npm run build",
        "predeploy:local": "npm run verify:local && npm run deploy:env-check && npm run agent:review",
        "deploy:target-check": "node scripts/deploy-target-check.js",
        "deploy:env-check": "node scripts/deploy-env-check.js",
        "release:dry-run": "node scripts/release.js --auto-commit --no-push",
        "release:fast": "node scripts/release.js --auto-commit --fast",
        "deploy:prod:auto": "npm run verify:local && powershell -ExecutionPolicy Bypass -File ./scripts/deploy-auto.ps1",
        "tmp:clean": "node scripts/clean-tmp-artifacts.js",
        "test": "vitest run",
        "test:ci": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "agent:review": "node scripts/agent-gate.js review",
        "agent:qa": "node scripts/agent-gate.js qa",
        "api:contract-audit": "node scripts/api-contract-audit.js",
        "api:contract-sync-audit": "node scripts/api-contract-sync-audit.js",
        "api:contract-check": "npm run api:contract-audit && npm run api:contract-sync-audit",
        "quality:standard": "npm run deploy:target-check && npm run typecheck && npm run lint:ci && npm run test:ci && npm run api:contract-check && npm run bench:workspace-search:ci && npm run smoke:ci",
        "smoke:ci": "node scripts/smoke.js",
        "refactor:analyze": "node scripts/refactor/analyzer.js",
        "refactor:apply": "node scripts/refactor/refactor-safe.js",
        "refactor:validate": "node scripts/refactor/validator.js",
        "refactor:loop": "node scripts/refactor/multi-agent-loop.js",
        "ingest:top20": "tsx ./scripts/run-top20-phases.ts",
        "ingest:top20:loop": "tsx ./scripts/run-top20-phases.ts --iterations=999999 --durationMinutes=180 --interval=20",
        "ingest:top20:agents": "tsx ./scripts/run-top20-agents.ts",
        "ingest:top20:agents:3h": "tsx ./scripts/run-top20-agents.ts --durationMinutes=180 --interval=20 --phases=A,B,C",
        "ops:autonomous": "tsx ./scripts/autonomous-ops-loop.ts",
        "ops:autonomous:3h": "tsx ./scripts/autonomous-ops-loop.ts --durationMinutes=180 --cycleMinutes=20 --autoCommit=false",
        "ops:autonomous:3h:dev": "tsx ./scripts/autonomous-ops-loop.ts --durationMinutes=180 --cycleMinutes=15 --ingest=false --refactor=true --apiAudits=true --healthCheck=true --autoCommit=false",
        "ops:autonomous:5h": "tsx ./scripts/autonomous-ops-loop.ts --durationMinutes=300 --cycleMinutes=20 --autoCommit=true",
        "ops:autonomous:5h:dev": "tsx ./scripts/autonomous-ops-loop.ts --durationMinutes=300 --cycleMinutes=20 --ingest=true --refactor=true --apiAudits=true --healthCheck=true --autoCommit=false",
        "ops:screen:3h": "tsx ./scripts/autonomous-ops-loop.ts --durationMinutes=180 --cycleMinutes=15 --ingest=false --refactor=true --apiAudits=true --healthCheck=true --autoCommit=false",
        "ops:review-list": "tsx ./scripts/autonomous-ops-loop.ts --reviewOnly=true",
        "ops:review-list:3h": "tsx ./scripts/autonomous-ops-loop.ts --reviewOnly=true --durationMinutes=180 --cycleMinutes=20 --reviewParallelism=3 --reviewTasksPerHour=100 --autoCommit=false",
        "ops:review-list:5h": "tsx ./scripts/autonomous-ops-loop.ts --reviewOnly=true --durationMinutes=300 --cycleMinutes=20 --autoCommit=false",
        "index:workspace": "tsx ./scripts/build-workspace-index.ts",
        "index:workspace:full": "tsx ./scripts/build-workspace-index.ts --full",
        "search:workspace": "tsx ./scripts/search-workspace.ts",
        "search:workspace:lean": "tsx ./scripts/search-workspace.ts -- --mode=lean",
        "search:workspace:full": "tsx ./scripts/search-workspace.ts -- --mode=full",
        "search:workspace:auto": "tsx ./scripts/search-workspace.ts -- --mode=auto",
        "bench:workspace-search": "tsx ./scripts/benchmark-workspace-search.ts",
        "bench:workspace-search:lean": "tsx ./scripts/benchmark-workspace-search.ts --modes=lean",
        "bench:workspace-search:full": "tsx ./scripts/benchmark-workspace-search.ts --modes=full",
        "bench:workspace-search:auto": "tsx ./scripts/benchmark-workspace-search.ts -- --modes=auto",
        "bench:workspace-search:ci": "tsx ./scripts/benchmark-workspace-search.ts --queries=metadata,page,admin,me,campaign --guard --guard-max-elapsed-ms=200 --guard-min-candidates=20 --guard-min-matches=100 --guard-max-fallback-rate=0.9"
    },
    "dependencies": {
        "@notionhq/client": "^5.11.0",
        "@prisma/client": "^6.19.2",
        "axios": "^1.13.5",
        "cheerio": "^1.2.0",
        "clsx": "^2.1.1",
        "dotenv": "^17.3.1",
        "framer-motion": "^12.34.3",
        "lucide-react": "^0.575.0",
        "next": "16.1.6",
        "next-themes": "^0.4.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "jsdom": "^28.1.0",
        "prisma": "^6.19.2",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vitest": "^4.0.18"
    },
    "optionalDependencies": {
        "@rollup/rollup-win32-x64-msvc": "^4.59.0",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.1",
        "lightningcss-win32-x64-msvc": "^1.31.1"
    }
}
